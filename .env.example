# Cloud SQL for PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/jeevadhara

# Vertex AI (Gemini) — GCP project running the three agents
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=asia-south1
# Paste the full service account JSON key as a single-line string (this is what
# Vercel needs — no filesystem to point a file path at). Locally you can use
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json instead, or run
# `gcloud auth application-default login` and leave both unset.
GCP_SERVICE_ACCOUNT_JSON=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
