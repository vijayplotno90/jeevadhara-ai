# Cloud SQL for PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/jeevadhara

# Vertex AI (Gemini) — GCP project running the three agents
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
# Path to a service account JSON key (local dev only — use Workload Identity / Vercel GCP integration in prod)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
